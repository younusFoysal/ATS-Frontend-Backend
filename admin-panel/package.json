{
  "name": "admin-panel",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "cbuild": "node scripts/custom-build.js",
    "build:docker": "NODE_OPTIONS=\"--max-old-space-size=4096\" vite build",
    "docker:build": "docker build -t younusfoysal/admin-panel:latest .",
    "docker:push": "docker push younusfoysal/admin-panel:latest",
    "docker:deploy": "npm run docker:build && npm run docker:push",
    "dockerx:setup": "docker buildx create --name multi --use || true && docker buildx inspect --bootstrap",

    "dockerx:deploy:plain": "docker buildx build --platform linux/amd64,linux/arm64 -t younusfoysal/admin-panel:latest --push . --progress=plain",
    "dockerx:deploy:sha:plain": "docker buildx build --platform linux/amd64,linux/arm64 -t younusfoysal/admin-panel:latest -t younusfoysal/admin-panel:$(git rev-parse --short HEAD) --push . --progress=plain",
    "dockerx:deploy:cached": "docker buildx build --platform linux/amd64,linux/arm64 --cache-from=type=registry,ref=younusfoysal/admin-panel:buildcache --cache-to=type=registry,ref=younusfoysal/admin-panel:buildcache,mode=max --provenance=false --sbom=false -t younusfoysal/admin-panel:latest --push . --progress=plain",
    "dockerx:deploy:sha:cached": "docker buildx build --platform linux/amd64,linux/arm64 --cache-from=type=registry,ref=younusfoysal/admin-panel:buildcache --cache-to=type=registry,ref=younusfoysal/admin-panel:buildcache,mode=max --provenance=false --sbom=false -t younusfoysal/admin-panel:latest -t younusfoysal/admin-panel:$(git rev-parse --short HEAD) --push . --progress=plain",
    "dockerx:deploy:amd64": "docker buildx build --platform linux/amd64 -t younusfoysal/admin-panel:amd64 --push . --progress=plain",
    "dockerx:verify": "docker buildx imagetools inspect younusfoysal/admin-panel:latest"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hello-pangea/dnd": "^18.0.1",
    "@hookform/resolvers": "^5.1.1",
    "@lottiefiles/dotlottie-react": "^0.13.2",
    "@react-pdf/renderer": "^4.3.0",
    "@remixicon/react": "^4.6.0",
    "@tailwindcss/line-clamp": "^0.4.4",
    "@tanstack/react-query": "^5.66.0",
    "@uiw/react-md-editor": "^4.0.11",
    "aos": "^2.3.4",
    "apexcharts": "^4.5.0",
    "axios": "^1.7.9",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "emoji-picker-react": "^4.13.2",
    "framer-motion": "^12.18.1",
    "interactjs": "^1.10.27",
    "jspdf": "^4.0.0",
    "jspdf-autotable": "^5.0.2",
    "lightgallery": "^2.9.0-beta.1",
    "lodash": "^4.17.21",
    "lucide-react": "^0.474.0",
    "next-themes": "^0.4.4",
    "pdfjs-dist": "^5.3.93",
    "react": "^18.3.1",
    "react-apexcharts": "^1.7.0",
    "react-csv": "^2.2.2",
    "react-datepicker": "^8.4.0",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "react-hook-form": "^7.61.0",
    "react-router-dom": "^7.1.5",
    "react-signature-canvas": "^1.1.0-alpha.2",
    "react-spinners": "^0.15.0",
    "react-toggle-dark-mode": "^1.1.1",
    "react-tooltip": "^5.28.0",
    "recharts": "^3.1.0",
    "remark-breaks": "^4.0.0",
    "remixicon": "^4.6.0",
    "socket.io-client": "^4.8.1",
    "sonner": "^1.7.4",
    "web-vitals": "^5.1.0",
    "zod": "^4.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@tailwindcss/typography": "^0.5.19",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "baseline-browser-mapping": "^2.8.31",
    "eslint": "^9.17.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "postcss": "^8.5.1",
    "prop-types": "^15.8.1",
    "react-hot-toast": "^2.5.1",
    "react-icons": "^5.4.0",
    "sass-embedded": "^1.85.1",
    "tailwindcss": "^3.4.17",
    "vite": "^6.0.5"
  },
  "overrides": {
    "@react-three/fiber": "^8.15.22",
    "react-reconciler": "^0.29.2",
    "its-fine": "^1.1.2",
    "@react-spring/three": "9.6.1",
    "react-native": "0.73.x"
  }
}
